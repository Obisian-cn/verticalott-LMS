{
  "name": "enrollment-service",
  "projectType": "application",
  "root": "enrollment-service",
  "sourceRoot": "enrollment-service/src",
  "targets": {
    "build": {
      "executor": "@nrwl/node:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/enrollment-service",
        "main": "enrollment-service/src/main.ts",
        "tsConfig": "enrollment-service/tsconfig.app.json",
        "assets": []
      }
    },
    "serve": {
      "executor": "@nrwl/node:node",
      "options": {
        "buildTarget": "enrollment-service:build",
        "watch": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo \"No lint configured for enrollment-service\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo \"No tests configured for enrollment-service\""
      }
    }
  }
}
