{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@lms/common/*": ["common/src/*"],
      "@lms/database/*": ["database/src/*"],
      "@lms/types/*": ["types/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
